      "LoginIdentityOptionVO": {
        "type": "object",
        "properties": {
          "identityCode": {
            "type": "string",
            "description": "身份编码。`CONSUMER` 消费者，`AGENT` 代理商，`SUPPLIER` 供货商。 请传字符串枚举值，不要传 Swagger 列表前面的数字序号。",
            "enum": [
              "CONSUMER",
              "AGENT",
              "SUPPLIER"
            ],
            "example": "CONSUMER"
          },
          "authDomain": {
            "type": "string",
            "description": "认证域。`MEMBER` 表示买家/会员域，`STORE` 表示供货商域。 请传字符串枚举值，不要传 Swagger 列表前面的数字序号。",
            "enum": [
              "MEMBER",
              "STORE"
            ],
            "example": "MEMBER"
          },
          "available": {
            "type": "boolean",
            "description": "是否允许当前会话直接进入该身份。`true` 可直接调用身份选择接口换取 token，`false` 需根据状态做引导。",
            "example": true
          },
          "status": {
            "type": "string",
            "description": "身份状态。`AVAILABLE` 可进入，`NOT_OPENED` 未开通，`PENDING` 审核中，`REJECTED` 审核拒绝，`DISABLED` 已禁用或未初始化。 请传字符串枚举值，不要传 Swagger 列表前面的数字序号。",
            "enum": [
              "AVAILABLE",
              "NOT_OPENED",
              "PENDING",
              "REJECTED",
              "DISABLED"
            ],
            "example": "AVAILABLE"
          },
          "message": {
            "type": "string",
            "description": "给前端展示的状态提示文案，可直接用于身份卡片上的辅助说明。",
            "example": "可直接进入消费者身份"
          },
          "nextAction": {
            "type": "string",
            "description": "当 `available=false` 时前端建议执行的后续动作。`NONE` 无需额外动作，`APPLY_AGENT` 申请代理商，`APPLY_STORE` 申请供货商，`RESUBMIT` 重新提交资料，`CONTACT_ADMIN` 联系管理员。 请传字符串枚举值，不要传 Swagger 列表前面的数字序号。",
            "enum": [
              "NONE",
              "APPLY_AGENT",
              "APPLY_STORE",
              "RESUBMIT",
              "CONTACT_ADMIN"
            ],
            "example": "NONE"
          }
        }
      },
