  "components": {
    "schemas": {
      "FileDirectory": {
        "type": "object",
        "description": "文件目录",
        "properties": {
          "directoryType": {
            "type": "string",
            "description": "文件目录类型"
          },
          "directoryName": {
            "type": "string",
            "description": "拥有者名称"
          },
          "ownerId": {
            "type": "string",
            "description": "拥有者id"
          },
          "parentId": {
            "type": "string",
            "description": "父分类ID"
          },
          "level": {
            "type": "integer",
            "format": "int32",
            "description": "层级",
            "maximum": 2,
            "minimum": 0
          }
        },
        "required": [
          "level"
        ]
      },
      "ResultMessageFileDirectory": {
        "type": "object",
        "description": "统一响应包装。success/code/message 描述业务结果，result 承载实际业务数据。",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "业务是否成功。true 表示成功，false 表示失败。"
          },
          "message": {
            "type": "string",
            "description": "业务提示文案。失败时请优先结合 code 判断，不要只依赖 message。"
          },
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "统一业务状态码。200 表示成功，其他值表示具体业务失败原因。",
            "example": 200
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "服务端生成的响应时间戳，毫秒。"
          },
          "result": {
            "$ref": "#/components/schemas/FileDirectory",
            "description": "真实业务数据载荷。"
          }
        }
      },
      "ResultMessageObject": {
        "type": "object",
        "description": "统一响应包装。success/code/message 描述业务结果，result 承载实际业务数据。",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "业务是否成功。true 表示成功，false 表示失败。"
          },
          "message": {
            "type": "string",
            "description": "业务提示文案。失败时请优先结合 code 判断，不要只依赖 message。"
          },
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "统一业务状态码。200 表示成功，其他值表示具体业务失败原因。",
            "example": 200
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "服务端生成的响应时间戳，毫秒。"
          },
          "result": {
            "description": "真实业务数据载荷。"
          }
        }
      },
      "ResultMessage": {
        "type": "object",
        "description": "统一响应包装。success/code/message 描述业务结果，result 承载实际业务数据。 统一响应包装。绝大多数接口都返回该结构。",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "业务是否成功。true 表示成功，false 表示失败。 业务是否成功。true 表示本次业务成功，false 表示业务失败。"
          },
