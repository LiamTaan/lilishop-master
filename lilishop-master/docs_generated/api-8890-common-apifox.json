    "/common/auth/login/sms": {
      "post": {
        "tags": [
          "App统一认证接口"
        ],
        "summary": "App-短信认证登录",
        "description": "校验短信验证码后创建 App 登录会话，不直接签发业务 token。成功后返回 `loginSessionToken` 和可选身份列表，前端需继续调用身份选择接口换取最终登录 token。若手机号未注册，系统会自动创建会员账号。",
        "operationId": "smsLogin",
        "parameters": [
          {
            "name": "uuid",
            "in": "header",
            "description": "短信验证码会话标识。需与发送验证码接口返回或前端持有的 `uuid` 保持一致，用于校验本次登录验证码。",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "5d2c6c4c-1c6d-4c35-8c5e-0f9b7aa12abc"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mobile": {
                    "type": "string",
                    "description": "用于登录或自动注册的手机号。若该手机号尚未注册，认证成功后系统会自动创建会员账号。",
                    "example": 13800138000,
                    "minLength": 1
                  },
                  "code": {
                    "type": "string",
                    "description": "登录短信验证码，需要与请求头中的 `uuid` 对应。",
                    "example": 123456,
                    "minLength": 1
                  }
                },
                "required": [
                  "code",
                  "mobile"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "请求参数缺失或格式错误，业务码 `4002`",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSessionSnapshotVO"
                }
              }
            }
          }
        }
      }
    },
    "/common/auth/login/one-click": {
      "post": {
        "tags": [
          "App统一认证接口"
        ],
        "summary": "App-本机号码一键登录认证",
        "description": "使用运营商一键登录凭证换取手机号并创建 App 登录会话，不直接签发业务 token。成功后返回 `loginSessionToken` 和可选身份列表，前端需继续调用身份选择接口换取最终登录 token。若换取到的手机号未注册，系统会自动创建会员账号。",
        "operationId": "oneClickLogin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "loginToken": {
                    "type": "string",
                    "description": "运营商或服务商返回的一键登录临时凭证。后端会基于该凭证换取手机号。",
                    "example": "eyJhbGciOiJIUzI1NiJ9.app-login-token",
                    "minLength": 1
                  }
                },
                "required": [
                  "loginToken"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "请求参数缺失或格式错误，业务码 `4002`",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSessionSnapshotVO"
                }
              }
            }
          }
        }
      }
    },
